  m_Script: {fileID: 11500000, guid: 3422be1e35dd61849beae5698838975d, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::TriggerTutorialZone
  message: "\u041F\u0440\u0438\u0432\u0435\u0442, \u043D\u0438\u043A\u0447\u0435\u043C\u043D\u044B\u0439
    \u043D\u0443\u0441\u043E\u043A \u043C\u0435\u0442\u0430\u043B\u043B\u0430. \u0422\u044B
    \u0431\u044B\u043B \u0441\u043E\u0431\u0440\u0430\u043D \u0434\u043B\u044F \u043E\u0434\u043D\u043E\u0439
    \u043D\u0435\u0437\u0430\u0442\u0435\u0439\u043B\u0438\u0432\u043E\u0439 \u043C\u0438\u0441\u0441\u0438\u0438.
    \u0414\u043B\u044F \u043D\u0430\u0447\u0430\u043B\u0430 \u0442\u0435\u0431\u0435
    \u043D\u0443\u0436\u043D\u043E \u043E\u0441\u0432\u043E\u0438\u0442\u044C\u0441\u044F
    \u0432 \u044D\u0442\u043E\u043C \u043D\u0435\u0441\u043F\u0440\u0430\u0432\u0435\u0434\u043B\u0438\u0432\u043E\u043C
    \u043C\u0438\u0440\u0435. \u0412 \u0440\u0443\u043A\u0435 \u0443 \u0442\u0435\u0431\u044F
    \u0443\u0441\u0442\u0440\u043E\u0439\u0441\u0442\u0432\u043E \u0440\u0430\u0437\u043C\u0435\u0449\u0435\u043D\u0438\u044F
    \u043F\u043E\u0440\u0442\u0430\u043B\u043E\u0432 (\u0423\u0420\u041F). \u0421
    \u0435\u0433\u043E \u043F\u043E\u043C\u043E\u0449\u044C\u044E \u043C\u043E\u0436\u043D\u043E
    \u0441\u043E\u0437\u0434\u0430\u0432\u0430\u0442\u044C \u043F\u043E\u0440\u0442\u0430\u043B\u044B
    \u043D\u0430 \u0441\u0442\u0435\u043D\u0430\u0445, \u043F\u043E\u043A\u0440\u044B\u0442\u044B\u0445
    \u041B\u0443\u043D\u043D\u043E\u0439 \u043F\u044B\u043B\u044C\u044E (\u0431\u0435\u043B\u044B\u0435).
    \u041F\u043E\u043F\u0440\u043E\u0431\u0443\u0439"
  playerTag: Player
  destroyAfterTrigger: 0
