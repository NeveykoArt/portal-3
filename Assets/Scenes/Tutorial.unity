    \u0440\u0430\u0441\u0441\u043A\u0430\u0437\u0430\u0442\u044C - \u0437\u0435\u0440\u043A\u0430\u043B\u044C\u043D\u0430\u044F
    \u043F\u043E\u0432\u0435\u0440\u0445\u043D\u043E\u0441\u0442\u044C. \u041F\u043E\u0440\u0442\u0430\u043B
    \u043D\u0435 \u043C\u043E\u0436\u0435\u0442 \u043F\u043E\u044F\u0432\u0438\u0442\u044C\u0441\u044F
    \u043D\u0430 \u043D\u0435\u0439, \u0437\u0430\u0442\u043E \u043F\u0440\u0435\u0432\u043E\u0441\u0445\u043E\u0434\u043D\u043E
    \u043E\u0442 \u043D\u0435\u0451 \u043E\u0442\u043B\u0435\u0442\u0430\u0435\u0442"
  playerTag: Player
  destroyAfterTrigger: 0
